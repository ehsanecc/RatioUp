{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "json": {
    "indentWidth": 2
  },
  "toml": {},
  "markdown": {
    "lineWidth": 100
  },
  "includes": ["**/*.{json,toml,md}"],
  "excludes": [
    "**/.git",
    "**/target",
    "Cargo.lock"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/toml-0.6.4.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm"
  ]
}
